<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Node Status Dashboard</title>
<style>
body {
	font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
	background-color: #f4f7f6;
	display: flex;
	justify-content: center;
	align-items: center;
	height: 100vh;
	margin: 0;
}

.card {
	background: white;
	padding: 2rem;
	border-radius: 12px;
	box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
	text-align: center;
	width: 400px;
	border-top: 5px solid #007bff;
}

h1 {
	color: #333;
	margin-bottom: 0.5rem;
	font-size: 1.5rem;
}

.status-badge {
	background: #28a745;
	color: white;
	padding: 4px 12px;
	border-radius: 20px;
	font-size: 0.8rem;
	text-transform: uppercase;
}

.info-box {
	margin-top: 1.5rem;
	text-align: left;
	background: #f8f9fa;
	padding: 1rem;
	border-radius: 8px;
}

.label {
	color: #666;
	font-size: 0.9rem;
}

.value {
	color: #007bff;
	font-weight: bold;
	font-family: 'Courier New', Courier, monospace;
}

.footer {
	margin-top: 1rem;
	font-size: 0.8rem;
	color: #999;
}
</style>
</head>
<body>
	<div class="card">
		<span class="status-badge">Node Online</span>
		<h1>System Information</h1>
		<p style="color: #666;">Automated Deployment via Ansible</p>

		<div class="info-box">
			<div>
				<span class="label">Node Hostname:</span> <span class="value">{{
					ansible_hostname }}</span>
			</div>
			<div style="margin-top: 10px;">
				<span class="label">IPv4 Address:</span> <span class="value">{{
					ansible_default_ipv4.address }}</span>
			</div>
			<div style="margin-top: 10px;">
				<span class="label">OS Family:</span> <span class="value">{{
					ansible_os_family }}</span>
			</div>
		</div>

	</div>
</body>
</html>